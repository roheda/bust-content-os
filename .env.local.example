NEXT_PUBLIC_FIREBASE_PROJECT_ID=bust-content-os
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=bust-content-os.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=677588846297
NEXT_PUBLIC_FIREBASE_APP_ID=1:677588846297:web:7cac21ac5a1c789dc960c8

# Cuando esté en true, ya no deja entrar con selector local y obliga login con Firebase Auth.
NEXT_PUBLIC_AUTH_ENFORCED=false

# Firebase Admin SDK para crear usuarios de Auth desde Usuarios.
# Se obtiene desde Firebase Console > Project settings > Service accounts > Generate new private key.
FIREBASE_ADMIN_PROJECT_ID=bust-content-os
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Token privado temporal para crear el primer acceso master antes de iniciar sesión.
# No es NEXT_PUBLIC. Solo vive en Vercel/servidor.
AUTH_SETUP_TOKEN=

OPENAI_API_KEY=
# Opcional. Si no se define, el sistema usa gpt-4.1-mini para texto.
OPENAI_TEXT_MODEL=gpt-4.1-mini
