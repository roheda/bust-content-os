rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function accessPath() {
      return /databases/(default)/documents/userAccess/$(request.auth.uid);
    }

    function hasAccessDoc() {
      return signedIn() && firestore.exists(accessPath());
    }

    function access() {
      return firestore.get(accessPath()).data;
    }

    function activeUser() {
      return hasAccessDoc() && access().status != "inactive";
    }

    function isMaster() {
      return activeUser() && (access().isMaster == true || access().roleKey == "master");
    }

    function hasPerm(moduleKey, actionKey) {
      return activeUser() && (
        isMaster() ||
        (
          "permissions" in access() &&
          moduleKey in access().permissions &&
          actionKey in access().permissions[moduleKey] &&
          access().permissions[moduleKey][actionKey] == true
        )
      );
    }

    function safeSize(maxMb) {
      return request.resource == null || request.resource.size < maxMb * 1024 * 1024;
    }

    match /clients/{clientId}/{allPaths=**} {
      allow read: if activeUser();
      allow create, update: if safeSize(80) && (hasPerm("clientes", "edit") || hasPerm("generador", "generate"));
      allow delete: if hasPerm("clientes", "delete") || hasPerm("clientes", "edit") || isMaster();
    }

    match /content-request-references/{allPaths=**} {
      allow read: if activeUser();
      allow create, update: if safeSize(80) && activeUser();
      allow delete: if hasPerm("tareas", "edit") || hasPerm("creador", "edit") || isMaster();
    }

    match /generated-images/{allPaths=**} {
      allow read: if activeUser();
      allow create, update: if safeSize(25) && hasPerm("generador", "generate");
      allow delete: if hasPerm("generador", "delete") || isMaster();
    }



    match /system-backups/{allPaths=**} {
      allow read: if activeUser();
      allow create, update: if safeSize(200) && (hasPerm("configuracion", "configure") || isMaster());
      allow delete: if hasPerm("configuracion", "configure") || isMaster();
    }

    // Para cualquier carpeta nueva: cerrado hasta definir regla explícita.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
